rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /people/{uid} {
      allow read: if true;
      allow create: if isValidDoc(request.resource.data);
      allow update: if isValidDoc(request.resource.data)
                    && request.resource.data.updatedAt >= resource.data.updatedAt;
      allow delete: if false;
    }

    function isValidDoc(d) {
      return d.keys().hasOnly(['name','books','rewardLabels','rewardInterval','updatedAt'])
        && d.name is string && d.name.size() < 200
        && d.books is list && d.books.size() < 500
        && d.updatedAt is timestamp
        && request.resource.size() < 900000;
    }
  }
}
